# forward-panel 反代示例(nginx)。把 panel.example.com 换成你的域名。
# 适用:deploy.sh 选了「反代模式」,面板监听 127.0.0.1:8080。
# 证书你自己准备(certbot / 已有证书均可)。

server {
    listen 80;
    server_name panel.example.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name panel.example.com;

    ssl_certificate     /etc/letsencrypt/live/panel.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/panel.example.com/privkey.pem;

    # 面板较大,放宽上传体积
    client_max_body_size 50m;

    location / {
        proxy_pass http://127.0.0.1:8080;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        # 关键:告诉面板原始请求是 HTTPS(强制 HTTPS 检查 + Secure cookie 靠它)
        proxy_set_header X-Forwarded-Proto https;

        # 网页终端是 WebSocket,必须转发 Upgrade
        proxy_http_version 1.1;
        proxy_set_header Upgrade    $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_read_timeout 3600s;
    }
}

# 注意:节点控制通道是 :9000(agent 直连 master 主机,裸 TCP/WS),
# 不经过本 nginx。若该端口被公网防火墙拦,需单独放通,或另配一个 stream 反代:
#
# stream {
#     server {
#         listen 9000;
#         proxy_pass 127.0.0.1:9000;
#     }
# }
